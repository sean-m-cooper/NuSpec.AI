<Project>
  <PropertyGroup>
    <_NuSpecAiToolPath>$(MSBuildThisFileDirectory)..\tools\net8.0\NuSpec.AI.Tool.dll</_NuSpecAiToolPath>
    <_NuSpecAiOutputDir>$(IntermediateOutputPath)nuspec-ai\</_NuSpecAiOutputDir>
    <_NuSpecAiOutputFile>$(_NuSpecAiOutputDir)package-map.json</_NuSpecAiOutputFile>
  </PropertyGroup>

  <!-- Register our target as a content provider for NuGet pack -->
  <PropertyGroup Condition="'$(NuSpecAiEnabled)' == 'true' and '$(IsPackable)' != 'false'">
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);NuSpecAiIncludePackageMap</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <!-- Generate the package-map.json file -->
  <Target Name="NuSpecAiGeneratePackageMap"
          BeforeTargets="NuSpecAiIncludePackageMap"
          Condition="'$(NuSpecAiEnabled)' == 'true' and '$(IsPackable)' != 'false'">

    <MakeDir Directories="$(_NuSpecAiOutputDir)" />

    <Exec Command="dotnet &quot;$(_NuSpecAiToolPath)&quot; &quot;$(MSBuildProjectFullPath)&quot; --output &quot;$(_NuSpecAiOutputFile)&quot;" />
  </Target>

  <!-- Add the generated file to the package -->
  <Target Name="NuSpecAiIncludePackageMap">
    <ItemGroup>
      <TfmSpecificPackageFile Include="$(_NuSpecAiOutputFile)">
        <PackagePath>ai/package-map.json</PackagePath>
      </TfmSpecificPackageFile>
    </ItemGroup>
  </Target>
</Project>
